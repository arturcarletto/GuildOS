# Docker Compose defaults for local development only.
POSTGRES_DB=guildos
POSTGRES_USER=guildos_app
POSTGRES_PASSWORD=guildos_local
POSTGRES_PORT=5432

# Runtime variables used when the local Spring profile is not active.
DB_URL=jdbc:postgresql://localhost:5432/guildos
DB_USERNAME=guildos_app
DB_PASSWORD=guildos_local

# Optional Discord Gateway settings. The integration is disabled by default.
GUILDOS_DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# Optional human operator login. Never commit a real Discord OAuth client secret.
# This root .env file is read by Docker Compose only; a Spring Boot process started
# directly reads these OAuth variables from its shell environment instead.
GUILDOS_IDENTITY_DISCORD_OAUTH_ENABLED=false
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8080/login/oauth2/code/discord
