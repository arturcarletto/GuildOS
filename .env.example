# Docker Compose defaults for local development only.
POSTGRES_DB=guildos
POSTGRES_USER=guildos_app
POSTGRES_PASSWORD=guildos_local
POSTGRES_PORT=5432

# Runtime variables used when the local Spring profile is not active.
DB_URL=jdbc:postgresql://localhost:5432/guildos
DB_USERNAME=guildos_app
DB_PASSWORD=guildos_local

